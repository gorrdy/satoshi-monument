# Zkopíruj do .env a vyplň hodnoty (.env je v .gitignore — necommitovat!)

DATABASE_URL="file:./dev.db"

# BTCPayServer (Greenfield API)
BTCPAY_URL="https://your-btcpayserver.example"
BTCPAY_STORE_ID=""
BTCPAY_API_KEY=""
BTCPAY_WEBHOOK_SECRET=""

# Fiat účet pro QR Platbu (SPAYD) — doplň vlastní
BANK_ACCOUNT=""
BANK_CODE=""
BANK_HOLDER=""

# Cíl sbírky v BTC
GOAL_BTC="1"

# Admin (silné, náhodné hodnoty!)
ADMIN_USERNAME="admin"
ADMIN_PASSWORD=""
SESSION_SECRET=""

# Veřejná URL webu
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# E-mail — denní report (volitelné)
SMTP_HOST=""
SMTP_PORT="465"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""
SMTP_REPLY_TO=""
ORGANIZER_EMAIL=""        # příjemce denního reportu
PROJECT_EMAIL=""          # kontaktní e-mail projektu

# Klíč pro cron endpointy (/api/cron/daily-report, /api/cron/fio-sync)
CRON_SECRET=""

# Fio API token (read-only) pro auto-potvrzování CZK plateb (volitelné)
FIO_TOKEN=""
