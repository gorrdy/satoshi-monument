generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Donation {
  id              String    @id @default(cuid())
  createdAt       DateTime  @default(now())

  name            String // jméno / přezdívka přispěvatele
  currency        String // "BTC" | "CZK"
  amount          Float // částka v zadané měně
  amountBtc       Float? // BTC ekvivalent, zafixovaný při potvrzení

  publicMessage   String? // zobrazí se na zdi přispěvatelů
  privateMessage  String? // jen pro organizátory
  imageUrl        String? // volitelné logo/obrázek na kartě (nastavuje admin, např. logo firmy)
  imageBg         String? // barva pozadí pod logem (hex, např. #ffffff)

  status          String    @default("pending") // pending | confirmed | rejected
  hiddenOnWall    Boolean   @default(false) // moderace veřejné zdi
  btcPurchased    Boolean   @default(false) // fiat: už za to bylo nakoupeno BTC na burze

  btcpayInvoiceId String? // pro BTC platby
  variableSymbol  String? // pro CZK platby (párování příchozího převodu)
  paymentRef      String? // krátký kód v poznámce platby pro snadné spárování
  donorKey        String? // identifikátor přispěvatele (e-mail/řetězec) pro sčítání plateb na zdi

  // Druh sbírky: "monument" = hlavní sbírka / Zeď Přispěvatelů (cíl 1 BTC),
  // "supporters" = Zeď Podporovatelů (průběžná, pojištění/údržba/péče).
  kind            String    @default("monument")

  confirmedAt     DateTime?

  @@index([status])
  @@index([createdAt])
  // Pokrývá filtr+řazení veřejných dotazů (zeď/recent/pending) — per druh sbírky.
  @@index([kind, status, hiddenOnWall, confirmedAt])
}

// Profil identifikátoru (donorKey): jedno kanonické jméno + logo, které přebíjí
// to, co zadá přispěvatel. Z platby se pak použije jen zpráva a částka.
model DonorProfile {
  id        String   @id @default(cuid())
  donorKey  String   @unique // normalizovaný identifikátor (lib/donorKey)
  name      String // kanonické jméno zobrazené na zdi i v recent
  imageUrl  String? // logo (http/https)
  imageBg   String? // barva pozadí pod logem (hex)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Anonymní záznam návštěvy (bezcookie analytika). Neukládá IP, jen denní hash.
model PageView {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  path        String
  locale      String?
  referrer    String? // jen doména nebo "direct"
  device      String // "mobile" | "desktop"
  isBot       Boolean  @default(false)
  visitorHash String // sha256(denní salt + IP + UA), bez PII

  @@index([createdAt])
  @@index([isBot])
}

// Příchozí platby z Fio, které se nepodařilo automaticky spárovat.
model FioPayment {
  id         String   @id @default(cuid())
  fioId      String   @unique // ID pohybu z Fio (dedupe)
  date       String?
  amount     Float
  currency   String
  vs         String?
  message    String?
  payerName  String?
  status     String   @default("unmatched") // unmatched | matched | ignored
  donationId String? // dar, ke kterému byla platba přiřazena
  createdAt  DateTime @default(now())

  @@index([status])
}

// Roadmapa / checkpointy sbírky (admin je spravuje, veřejně se zobrazují).
model RoadmapItem {
  id        String   @id @default(cuid())
  title     String
  detail    String? // volitelný popis
  dateLabel String? // přibližné datum/termín (volný text, např. „Q3 2026")
  status    String   @default("upcoming") // done | current | upcoming
  linkUrl   String? // volitelný proklik (http/https)
  linkBlank Boolean  @default(true) // otevřít odkaz v novém okně
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([order])
}
